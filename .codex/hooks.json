{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_PROJECT_DIR}/.codex/hooks/check_bilingual_docs.sh"
          },
          {
            "type": "command",
            "command": "${CODEX_PROJECT_DIR}/.codex/hooks/check_monitoring_docs.sh"
          }
        ]
      }
    ]
  }
}
