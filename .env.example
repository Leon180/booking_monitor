# ==============================================================================
# Booking Monitor — environment template
# ==============================================================================
# Copy this file to `.env` and replace every value before running
# `docker-compose up` or any `make` target that talks to a container.
# `.env` is gitignored; this `.env.example` is tracked as documentation.
#
# The file is split into two sections:
#   • SECRETS     — values that leak = incident. In k8s these go into a
#                   Secret (read via `envFrom.secretRef`) or an external
#                   secret manager (Vault, AWS Secrets Manager, etc.).
#   • CONFIG      — non-sensitive tuning and service discovery. In k8s
#                   these go into a ConfigMap (`envFrom.configMapRef`).
#
# If you add a new variable, decide which section it belongs in by
# asking: "would I be in trouble if this leaked to a public git repo?"
# Yes → SECRETS. No → CONFIG.
# ==============================================================================


# ══════════════════════════════════════════════════════════════════════════════
#  SECRETS
#  Leak = credential rotation + post-mortem. Never commit real values.
# ══════════════════════════════════════════════════════════════════════════════

# --- Postgres credentials ---
# Used by the postgres container AND embedded in the DATABASE_URL below.
POSTGRES_USER=booking
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=booking

# Convenience URL assembled from the values above. Keep in sync if you
# change user/password. Contains the password → treat as secret. The host
# `postgres` resolves inside the compose network; host-side Make targets
# use the `MIGRATE_DB_URL` below instead.
DATABASE_URL=postgres://booking:change_me_postgres@postgres:5432/booking?sslmode=disable

# Host-side DB URL for migrations run from the host against the published
# 5433 port. Must reference localhost, not `postgres`. Also embeds the
# password → treat as secret.
MIGRATE_DB_URL=postgres://booking:change_me_postgres@localhost:5433/booking?sslmode=disable

# --- Redis credentials ---
# REDIS_PASSWORD is REQUIRED — redis starts with `--requirepass` in
# docker-compose.yml and booking-cli reads it via RedisConfig.Password.
REDIS_PASSWORD=change_me_redis

# --- Grafana admin ---
GRAFANA_ADMIN_PASSWORD=change_me_grafana

# --- Payment webhook signing secret (D5) ---
# REQUIRED. The HMAC key the provider shares with us; the verifier
# refuses to start with an empty value (HMAC over an empty key is
# forgeable, so an empty secret would silently accept every signature).
# Production: this is the secret the provider's dashboard issues
# (Stripe: `whsec_...`). Leak = forge-any-webhook incident; rotate
# immediately and treat as a security event.
PAYMENT_WEBHOOK_SECRET=whsec_local_dev_secret_change_me_in_prod


# ══════════════════════════════════════════════════════════════════════════════
#  CONFIG (non-secret)
#  Safe to commit defaults. In k8s these go into a ConfigMap.
# ══════════════════════════════════════════════════════════════════════════════

# --- Service addresses (internal DNS names, not secret) ---
REDIS_ADDR=booking_redis:6379
KAFKA_BROKERS=kafka:9092

# --- Grafana ---
GRAFANA_ADMIN_USER=admin

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=booking-service
# Fraction of requests sampled for OTEL tracing. 1.0 = every request
# (good for debugging, terrible for GC at high traffic). 0.01 = 1%
# (good for production dashboards). 0 = off.
OTEL_TRACES_SAMPLER_RATIO=0.01

# --- App ---
GIN_MODE=release
APP_ENV=production

# --- GC Tuning ---
# GOGC controls GC trigger frequency. Default 100 = trigger when heap
# doubles. Higher = less frequent GC but more peak memory. 400 is a
# good balance for high-RPS services (reduces GC from ~12/sec to ~3/sec).
GOGC=400
# GOMEMLIMIT (Go 1.19+) soft memory limit. Pairs with GOGC — GC becomes
# more aggressive as heap approaches this limit, preventing OOM while
# keeping GC lazy during normal operation. Set to ~2x observed peak heap.
GOMEMLIMIT=256MiB

# --- Profiling ---
# Set to "true" to start the pprof server on :6060. Do NOT enable in
# production without network-level access control.
ENABLE_PPROF=false

# --- Payment webhook tunables (D5) ---
# The signing secret itself lives in the SECRETS block above
# (`PAYMENT_WEBHOOK_SECRET`); only its non-secret companions live here.
#
# Allowed clock skew between the provider's `t=<unix>` signature
# component and our wall clock. 5m matches Stripe's documented default.
PAYMENT_WEBHOOK_REPLAY_TOLERANCE=5m
# Expected `livemode` flag on inbound envelopes. false in dev / staging
# (provider sends test webhooks); true once you switch to a live key.
# A mismatch is 200-no-op'd (cross-env leak guard) so a misrouted test
# webhook can't error-storm a prod listener.
PAYMENT_WEBHOOK_EXPECTED_LIVE_MODE=false
# When true, mounts /test/payment/confirm/:order_id (signs an envelope
# and POSTs back to /webhook/payment to drive the full pipeline). MUST
# be false in production — leaving it true exposes a path that can flip
# any awaiting_payment order via the production webhook secret.
ENABLE_TEST_ENDPOINTS=false

# --- Worker (order-stream consumer) ---
# Per-environment knobs for internal/infrastructure/cache/redis_queue.go.
# Wire-contract values (stream/group/dlq names, XADD field names) are
# deliberately NOT here — those stay as code constants because per-replica
# overrides would silently split-brain the producer/consumer.
#
# WORKER_STREAM_READ_COUNT — XReadGroup batch size. Higher = more
# throughput per call, more memory per goroutine.
WORKER_STREAM_READ_COUNT=10
# WORKER_STREAM_BLOCK_TIMEOUT — XReadGroup block window. Lower = faster
# shutdown, higher CPU; higher = lower CPU, slower shutdown detection.
WORKER_STREAM_BLOCK_TIMEOUT=2s
# WORKER_MAX_RETRIES — per-message retry budget before DLQ.
# Deterministic-failure errors bypass the budget via the retry policy.
WORKER_MAX_RETRIES=3
# WORKER_RETRY_BASE_DELAY — base for linear backoff (attempt N waits
# N * base). Keep modest; a future PR will switch to exponential+jitter.
WORKER_RETRY_BASE_DELAY=100ms
# WORKER_FAILURE_TIMEOUT — handleFailure compensation budget (Redis
# revert + DLQ XAdd). Runs against a fresh background ctx so it survives
# parent-ctx cancellation.
WORKER_FAILURE_TIMEOUT=5s
# WORKER_PENDING_BLOCK_TIMEOUT — XReadGroup block window for the
# startup PEL recovery sweep. Short so cold-boot shutdown is prompt.
WORKER_PENDING_BLOCK_TIMEOUT=100ms
# WORKER_READ_ERROR_BACKOFF — sleep between XReadGroup-failure retries.
WORKER_READ_ERROR_BACKOFF=1s

# --- Redis cache TTLs ---
# REDIS_INVENTORY_TTL — how long event:{uuid}:qty inventory keys live.
# Long-by-default so active events stay cached; orphaned keys from
# deleted events fall off Redis instead of accumulating forever.
REDIS_INVENTORY_TTL=720h
# REDIS_IDEMPOTENCY_TTL — how long Idempotency-Key cached responses
# live. Must align with longest client retry window.
REDIS_IDEMPOTENCY_TTL=24h
# REDIS_MAX_CONSECUTIVE_READ_ERRORS — bounds tolerance for a broken
# Redis before the worker exits and lets k8s restart the pod.
REDIS_MAX_CONSECUTIVE_READ_ERRORS=30
