# Copy to terraform.tfvars and fill in. NEVER commit terraform.tfvars
# (the .gitignore in this directory excludes it; do not bypass).

# ----- Required -----

# GCP project to deploy into. If create_project=false, must already exist.
project_id = "booking-monitor-prod"

# GitHub owner + repo. Used in WIF trust to scope which repository's
# workflows are allowed to impersonate the CI service accounts.
github_owner = "Leon180"
github_repo  = "booking_monitor"

# ----- Optional -----

# If true, Terraform creates the project from scratch and links the
# billing account. If false, the project must exist; Terraform just
# manages resources inside it.
create_project = false

# Required only when create_project=true. Look up via:
#   gcloud beta billing accounts list
billing_account_id = ""

# Region. e2-micro Always-Free is only available in:
#   us-central1, us-east1, us-west1
# Any other region drops to paid tier (~$7/mo for the same instance).
region = "us-central1"

# Zone suffix (a/b/c) within the region. Cosmetic; e2-micro tier is
# per-project not per-zone.
vm_zone_suffix = "a"
