# ==============================================================================
# Booking Monitor — VM-suitable .env BASE template
# ==============================================================================
# Used by `scripts/secrets_sync.sh` as the base layer when constructing
# /opt/booking-monitor/.env on the GCE VM. Secret values come from
# Secret Manager and are OVERLAID on top of this template.
#
# Key differences vs the local-dev `.env.example`:
#   * Hostnames are compose-internal (booking_db, booking_redis, etc.) —
#     NOT localhost (because the app talks to other compose services).
#   * Secret values are placeholders (PLACEHOLDER_*); secrets_sync.sh
#     replaces them at deploy time.
#   * Conservative production-grade defaults (GOGC=400, samplers=0.01).
#
# DO commit this file to git. It does NOT contain secrets — placeholder
# values are checked before serving traffic (any actual PLACEHOLDER_* in
# the running .env means secrets_sync didn't run).
# ==============================================================================

# --- Postgres (compose-internal hostname) ---
POSTGRES_USER=booking
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=booking
# Secret Manager overlays DATABASE_URL + MIGRATE_DB_URL via secrets_sync.sh.
DATABASE_URL=PLACEHOLDER_DATABASE_URL_FROM_SECRET_MANAGER
MIGRATE_DB_URL=PLACEHOLDER_DATABASE_URL_FROM_SECRET_MANAGER

# --- Redis ---
REDIS_ADDR=booking_redis:6379
REDIS_PASSWORD=PLACEHOLDER_REDIS_PASSWORD_FROM_SECRET_MANAGER

# --- Kafka ---
KAFKA_BROKERS=booking_kafka:9092

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://booking_jaeger:4318
OTEL_SERVICE_NAME=booking-monitor
OTEL_TRACES_SAMPLER_RATIO=0.01

# --- Runtime tuning ---
GIN_MODE=release
APP_ENV=production
GOGC=400
GOMEMLIMIT=256MiB
ENABLE_PPROF=false

# --- Worker tuning ---
WORKER_STREAM_READ_COUNT=10
WORKER_STREAM_BLOCK_TIMEOUT=2s
WORKER_MAX_RETRIES=3
WORKER_RETRY_BASE_DELAY=100ms
WORKER_FAILURE_TIMEOUT=5s
WORKER_PENDING_BLOCK_TIMEOUT=100ms
WORKER_READ_ERROR_BACKOFF=1s
REDIS_INVENTORY_TTL=720h
REDIS_IDEMPOTENCY_TTL=24h
REDIS_MAX_CONSECUTIVE_READ_ERRORS=30

# --- Reconciler ---
RECON_SWEEP_INTERVAL=120s
RECON_CHARGING_THRESHOLD=120s
RECON_GATEWAY_TIMEOUT=10s
RECON_MAX_CHARGING_AGE=24h
RECON_BATCH_SIZE=100

# --- Saga watchdog ---
SAGA_WATCHDOG_INTERVAL=60s
SAGA_STUCK_THRESHOLD=60s
SAGA_MAX_FAILED_AGE=24h
SAGA_BATCH_SIZE=100

# --- Expiry sweeper ---
EXPIRY_SWEEP_INTERVAL=60s
EXPIRY_BATCH_SIZE=100
BOOKING_RESERVATION_WINDOW=15m

# --- Payment (mock by default; flip to stripe when ready) ---
PAYMENT_PROVIDER=mock
STRIPE_API_KEY=PLACEHOLDER_STRIPE_API_KEY_FROM_SECRET_MANAGER
STRIPE_WEBHOOK_SECRET=PLACEHOLDER_STRIPE_WEBHOOK_SECRET_FROM_SECRET_MANAGER
STRIPE_API_TIMEOUT=30s
STRIPE_MAX_NETWORK_RETRIES=2
STRIPE_ALLOW_TEST_KEY=false
ENABLE_TEST_ENDPOINTS=false

# --- D5 webhook ---
PAYMENT_WEBHOOK_SECRET=PLACEHOLDER_PAYMENT_WEBHOOK_SECRET_FROM_SECRET_MANAGER
PAYMENT_WEBHOOK_REPLAY_TOLERANCE=5m
PAYMENT_WEBHOOK_EXPECTED_LIVE_MODE=false

# --- Admin streaming ---
ADMIN_STREAM_JWT_SECRET=
ADMIN_STREAM_JWT_MAX_TTL=1h

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=PLACEHOLDER_GRAFANA_ADMIN_PASSWORD_FROM_SECRET_MANAGER

# --- CORS ---
CORS_ALLOWED_ORIGINS=
