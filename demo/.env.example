# Booking Monitor — D8 browser demo env (dev only).
#
# Vite reads VITE_-prefixed vars at build time and inlines them into
# the bundle. Copy this file to `.env.local` (gitignored) before
# running `npm run dev` if you need to override the default.
#
# VITE_API_ORIGIN — origin of the booking_monitor API surface.
# The demo derives:
#   v1Base   = ${VITE_API_ORIGIN}/api/v1   (book, pay, poll, events)
#   testBase = ${VITE_API_ORIGIN}/test     (mock /test/payment/confirm)
#
# Default: http://localhost (nginx, the only host-published port in
# docker-compose.yml). Override to http://localhost:8080 if running
# the Go binary directly via `make run-server`.
#
# IMPORTANT: the API server's CORS_ALLOWED_ORIGINS env must include
# the URL the browser loads this app from (default Vite dev server:
# http://localhost:5173 + http://127.0.0.1:5173). Without that, the
# browser blocks every fetch with a CORS error.
VITE_API_ORIGIN=http://localhost
